THINKROUTER_DB_PATH=results/traces/thinkrouter.sqlite

# Optional trained router models. Leave unset to use heuristic routing.
THINKROUTER_DIFFICULTY_MODEL_PATH=results/models/difficulty.joblib
THINKROUTER_BUDGET_MODEL_PATH=results/models/budget.joblib

# OpenAI-compatible endpoint. Works with OpenAI, OpenRouter, SiliconFlow,
# and vLLM servers exposing /v1/chat/completions.
# Keep mock models for local no-cost development. Set non-mock model ids
# before running real endpoint smoke tests or real grids.
THINKROUTER_OPENAI_BASE_URL=https://api.openai.com/v1
THINKROUTER_OPENAI_API_KEY=replace-me
THINKROUTER_CHEAP_MODEL=mock-cheap
THINKROUTER_STRONG_MODEL=gpt-4o-mini

# Approximate USD cost per 1K tokens for local estimates.
THINKROUTER_CHEAP_COST_PER_1K=0.0
THINKROUTER_STRONG_COST_PER_1K=0.0006